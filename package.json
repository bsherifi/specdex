    "eslint-plugin-react-refresh": "0.4.7",
    "jsdom": "24.1.0",
    "prettier": "3.3.2",
    "selenium-webdriver": "4.23.0",
    "tailwindcss": "4.3.0",
    "typescript": "5.5.3",
    "vite": "5.3.3",
    "vitest": "2.0.0"

# Generated by Cargo
# will have compiled files and executables
debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# Internal overnight-build automation — kept local, not published
.specdex/

# Rust
/target
**/*.rs.bk
Cargo.lock.bak

# Tauri build artifacts (placeholder; plan 02 expands this)
src-tauri/target

# Node / Vite
node_modules/
dist/
.vite/

# Tauri dev artifacts
src-tauri/gen/
.tauri/

# Bundled binaries (downloaded at build time)
src-tauri/binaries/*
!src-tauri/binaries/.gitkeep

# Third-party reference repo kept locally for inspiration — never published
customiser-frontend-repo-inspo/

# Internal docs / design notes — kept local, not published
docs/

# Editor / OS
.DS_Store
*.log
.vscode/
.idea/

# Playwright
playwright-report/
test-results/
e2e/.cache/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/
